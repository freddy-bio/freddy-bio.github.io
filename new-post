#!/bin/zsh

set -e
set -u
set -o pipefail

usage() {
  cat <<'EOF'
Usage: ./new-post "Post Title" [category]

Creates a new Jekyll post in _posts with the correct filename and front matter.
The default category is "notes".
After creating the file, the script opens it in your editor.
EOF
}

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

title="$1"
category="${2:-notes}"
root_dir="$(cd "$(dirname "$0")" && pwd)"
posts_dir="$root_dir/_posts"

if [[ ! -d "$posts_dir" ]]; then
  echo "Missing posts directory: $posts_dir" >&2
  exit 1
fi

open_in_editor() {
  local path="$1"
  local editor_cmd=()

  if [[ -n "${VISUAL:-}" ]]; then
    editor_cmd=("${(z)VISUAL}")
  elif [[ -n "${EDITOR:-}" ]]; then
    editor_cmd=("${(z)EDITOR}")
  elif command -v code >/dev/null 2>&1; then
    editor_cmd=("code" "-w")
  elif command -v nano >/dev/null 2>&1; then
    editor_cmd=("nano")
  elif [[ "$OSTYPE" == darwin* ]]; then
    editor_cmd=("open" "-t")
  else
    editor_cmd=("vi")
  fi

  "${editor_cmd[@]}" "$path"
}

slug="$(ruby -e 'title = ARGV[0].to_s.strip.downcase; slug = title.gsub(/[^a-z0-9]+/, "-").gsub(/\A-+|-+\z/, ""); exit 1 if slug.empty?; puts slug' -- "$title")"
escaped_title="$(ruby -e 'value = ARGV[0].to_s.gsub("\\\\", "\\\\\\\\").gsub("\"", "\\\\\""); puts value' -- "$title")"
escaped_category="$(ruby -e 'value = ARGV[0].to_s.gsub("\\\\", "\\\\\\\\").gsub("\"", "\\\\\""); puts value' -- "$category")"

filename="$(date +"%Y-%m-%d")-$slug.md"
filepath="$posts_dir/$filename"
timestamp="$(date +"%Y-%m-%d %H:%M:%S %z")"

if [[ -e "$filepath" ]]; then
  echo "Post already exists: $filepath" >&2
  exit 1
fi

cat > "$filepath" <<EOF
---
layout: post
title: "$escaped_title"
date: $timestamp
categories: ["$escaped_category"]
---

Write here.
EOF

echo "Created $filepath"
echo "Opening in editor..."
open_in_editor "$filepath"
echo "Next:"
echo "  1. Edit the file"
echo "  2. git add _posts/$filename"
echo "  3. git commit -m \"Add post: $title\""
echo "  4. git push origin main"
